import os

# Build arguments
ARG BUILDPLATFORM
ARG TARGETPLATFORM

# Environment
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/omnivideo
SYNC_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/omnivideo

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Storage (MinIO/S3)
S3_ENDPOINT_URL=http://localhost:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_S3_BUCKET=omnivideo-uploads
AWS_S3_REGION=us-east-1

# Security
JWT_SECRET_KEY=change-this-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# API Keys
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# App
APP_NAME=OmniVideo AI
APP_VERSION=1.0.0
DEBUG=false
TEMP_DIR=/tmp/omnivideo
MAX_UPLOAD_SIZE=10737418240

# FFMPEG
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# CORS
CORS_ORIGINS=["http://localhost:3000","https://omnivideo.ai"]

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_UPLOAD_PER_HOUR=10
